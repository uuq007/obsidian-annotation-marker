{
  "name": "obsidian-annotation-marker",
  "version": "2.0.2",
  "description": "Obsidian标注插件 - 在不改动原始Markdown文件的前提下，为Markdown文件添加标注、高亮和批注",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit -skipLibCheck",
    "test": "vitest run",
    "dev": "node esbuild.config.mjs",
    "build": "npm run typecheck && node esbuild.config.mjs production"
  },
  "keywords": [
    "obsidian",
    "annotation",
    "highlight",
    "markdown",
    "marker"
  ],
  "license": "MIT",
  "author": "uuq007",
  "devDependencies": {
    "@types/node": "^16.11.6",
    "esbuild": "0.25.5",
    "tslib": "2.4.0",
    "typescript": "^5.8.3",
    "vitest": "^0.34.6"
  },
  "dependencies": {
    "obsidian": "latest"
  }
}
