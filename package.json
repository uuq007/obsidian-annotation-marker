{
  "name": "obsidian-annotation-marker",
  "version": "3.0.5",
  "description": "Obsidian标注插件 - 为 Markdown 笔记添加标注、高亮和批注",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
