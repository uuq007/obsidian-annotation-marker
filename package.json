    "annotation",
    "highlight",
    "markdown",
    "marker"
  ],
  "license": "MIT",
  "author": "uuq007",
  "devDependencies": {
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@types/node": "^16.11.6",
    "esbuild": "0.25.5",
    "tslib": "2.4.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "diff": "^8.0.3",
    "obsidian": "latest"
  }
}
